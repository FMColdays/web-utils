{
  "name": "@fmcoldays/notify",
  "version": "3.0.0",
  "description": "Toasts animados, confirm y notify. Sin dependencias externas, inyecta sus propios estilos.",
  "author": "fmcoldays",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "toast",
    "notification",
    "confirm",
    "notify",
    "dialog",
    "svg",
    "dom"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
