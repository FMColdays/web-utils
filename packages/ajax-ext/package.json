{
  "name": "@fmcoldays/ajax-ext",
  "version": "0.2.0",
  "description": "Extiende data-ajax de jQuery Unobtrusive Ajax con confirmacion async, loading states, toasts y navegacion declarativa via atributos data-ajax-ext-*.",
  "author": "fmcoldays",
  "license": "MIT",
  "type": "module",
  "sideEffects": true,
  "keywords": [
    "ajax",
    "unobtrusive",
    "aspnet",
    "toast",
    "confirm",
    "loading",
    "data-attributes"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fmcoldays/toast": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
