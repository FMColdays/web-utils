{
  "name": "@fmcoldays/dropzone",
  "version": "0.4.1",
  "description": "Zona de carga de archivos con drag & drop, previsualización, lightbox de imágenes y subida inmediata. Auto-inicializa vía MutationObserver (sirve en modales y partiales AJAX).",
  "author": "fmcoldays",
  "license": "MIT",
  "type": "module",
  "sideEffects": true,
  "keywords": ["dropzone", "file-upload", "drag-and-drop", "lightbox", "dom"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fmcoldays/shared": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
