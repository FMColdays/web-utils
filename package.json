{
  "name": "@fmcoldays/web-utils",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo de utilidades web reutilizables (post-action, modal) de fmcoldays.",
  "author": "fmcoldays",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "dev": "pnpm -r --parallel --filter \"./packages/**\" dev",
    "typecheck": "pnpm -r --filter \"./packages/**\" typecheck",
    "clean": "pnpm -r --filter \"./packages/**\" clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
